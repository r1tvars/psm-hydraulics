{#
/**
 * @file
 * Theme override to display a single page.
 */
#}
<div class="site-shell">
  <header class="border-b border-steel-200 bg-white" role="banner">
    <div class="border-b border-steel-200 bg-white">
      <div class="site-section flex flex-col gap-3 text-steel-500 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-6 sm:gap-y-2">
          {% if psm_site_contact.phone %}
            <a class="header-top-item hover:text-brand" href="tel:{{ psm_site_contact.phone|replace({' ': '', '(': '', ')': '', '-': ''}) }}">
              <i class="fa-solid fa-phone text-brand" aria-hidden="true"></i>
              <span>{{ psm_site_contact.phone }}</span>
            </a>
          {% endif %}
          {% if psm_site_contact.email %}
            <a class="header-top-item hover:text-brand" href="mailto:{{ psm_site_contact.email }}">
              <i class="fa-solid fa-envelope text-brand" aria-hidden="true"></i>
              <span>{{ psm_site_contact.email }}</span>
            </a>
          {% endif %}
          {% if psm_site_contact.location %}
            <div class="header-top-item">
              <i class="fa-solid fa-location-dot text-brand" aria-hidden="true"></i>
              <span>{{ psm_site_contact.location }}</span>
            </div>
          {% endif %}
        </div>

        <div class="flex items-center md:ml-6">
          <a class="header-icon-link" href="#" aria-label="Facebook">
            <i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
          </a>
          <a class="header-icon-link" href="#" aria-label="Twitter">
            <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
          </a>
          <a class="header-icon-link" href="#" aria-label="LinkedIn">
            <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
          </a>
          <a class="header-icon-link border-r border-steel-200" href="#" aria-label="Instagram">
            <i class="fa-brands fa-instagram" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="site-section py-5 lg:py-0">
      <div class="flex flex-col gap-5 xl:flex-row xl:items-center xl:justify-between">
        <div class="flex items-center justify-between gap-4">
          {{ page.header }}
          <a class="header-action-link xl:hidden" href="#main-navigation" aria-label="Jump to site menu">
            <i class="fa-solid fa-bars" aria-hidden="true"></i>
          </a>
        </div>

        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:gap-6 w-full">
          <nav class="header-nav mr-auto" aria-label="Primary navigation" id="main-navigation">
            {{ page.primary_menu }}
          </nav>

          <div class="flex items-center justify-between gap-3 xl:justify-end">
            {% if page.secondary_menu %}
              <div class="header-secondary">
                {{ page.secondary_menu }}
              </div>
            {% endif %}

            <div class="flex items-center gap-3">
              <a class="header-action-link" href="/contact" aria-label="Contact page">
                <i class="fa-regular fa-envelope" aria-hidden="true"></i>
              </a>
              <a class="header-action-link" href="/search/node" aria-label="Search">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  {% if page.breadcrumb %}
    <div class="site-section">
      {{ page.breadcrumb }}
      {{ page.help }}
    </div>
  {% endif %}

  <main class="content-shell" role="main">
    <a id="main-content" tabindex="-1"></a>

    {% if messages %}
      <div class="site-section pt-6">
        {{ messages }}
      </div>
    {% endif %}

    <div>
      {{ page.content }}
    </div>
  </main>

  {% if page.footer %}
    <footer class="mt-12 border-t border-steel-200 bg-white py-10" role="contentinfo">
      <div class="site-section">
        {{ page.footer }}
      </div>
    </footer>
  {% endif %}
</div>
