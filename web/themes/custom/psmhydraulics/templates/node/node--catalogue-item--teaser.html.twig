<article{{ attributes.addClass('catalogue-card') }}>
  <a class="catalogue-card__link" href="{{ url }}" rel="bookmark">
    <div class="catalogue-card__media">
      {% if catalogue_item_category %}
        <span class="catalogue-card__badge">{{ catalogue_item_category }}</span>
      {% endif %}

      {% if catalogue_item_image_url %}
        <img
          class="catalogue-card__image"
          src="{{ catalogue_item_image_url }}"
          alt="{{ catalogue_item_image_alt }}"
          loading="lazy"
        >
      {% else %}
        <div class="catalogue-card__placeholder">
          <span>No image</span>
        </div>
      {% endif %}
    </div>

    <div class="catalogue-card__body">
      {% if catalogue_item_sku %}
        <p class="catalogue-card__sku">{{ catalogue_item_sku }}</p>
      {% endif %}

      <h2 class="catalogue-card__title">{{ label }}</h2>

      {% if catalogue_item_price_status %}
        <p class="catalogue-card__price">{{ catalogue_item_price_status }}</p>
      {% endif %}
    </div>
  </a>
</article>
