{{ attach_library('psmhydraulics/language-switcher') }}

{% if psm_language_switcher.items %}
  <div class="language-switcher" data-language-switcher data-open="false">
    <button class="language-switcher__trigger" type="button" aria-expanded="false" aria-haspopup="true" data-language-switcher-trigger>
      <span class="{{ psm_language_switcher.current_flag_class }} language-switcher__flag" aria-hidden="true"></span>
      <span class="language-switcher__label">{{ psm_language_switcher.current_label }}</span>
      <span class="language-switcher__chevron" aria-hidden="true">
        <i class="fa-solid fa-chevron-down"></i>
      </span>
    </button>

    <div class="language-switcher__panel hidden" data-language-switcher-panel>
      <ul class="language-switcher__list">
        {% for item in psm_language_switcher.items %}
          <li class="language-switcher__item{{ item.is_active ? ' is-active' : '' }}">
            <span class="{{ item.flag_class }} language-switcher__flag" aria-hidden="true"></span>
            {% if item.link %}
              {{ item.link }}
            {% else %}
              <span class="language-switcher__link">{{ item.label }}</span>
            {% endif %}
            {% if item.is_active %}
              <span class="language-switcher__active" aria-hidden="true">
                <i class="fa-solid fa-check"></i>
              </span>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
{% endif %}
