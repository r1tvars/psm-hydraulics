<article{{ attributes.addClass('statistics-bar-item') }}>
  {% if statistics_bar_link %}
    {{ statistics_bar_link }}
  {% endif %}

  {% if not paragraph.field_stat_value.isEmpty() %}
    <div
      class="statistics-bar-item__value"
      data-statistics-counter
      data-statistics-counter-target="{{ paragraph.field_stat_value.value|e('html_attr') }}"
    >
      {{ content.field_stat_value }}
    </div>
  {% endif %}

  {% if not paragraph.field_heading.isEmpty() %}
    <h3 class="statistics-bar-item__heading">
      {{ content.field_heading }}
    </h3>
  {% endif %}

  {% if not paragraph.field_description.isEmpty() %}
    <div class="statistics-bar-item__description">
      {{ content.field_description }}
    </div>
  {% endif %}
</article>
