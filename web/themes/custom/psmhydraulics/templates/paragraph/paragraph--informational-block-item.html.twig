<article{{ attributes.addClass('informational-block-item') }}>
  {% if not paragraph.field_heading.isEmpty() %}
    <h3 class="informational-block-item__heading">
      {{ content.field_heading }}
    </h3>
  {% endif %}

  {% if not paragraph.field_description.isEmpty() %}
    <div class="informational-block-item__description">
      {{ content.field_description }}
    </div>
  {% endif %}
</article>
