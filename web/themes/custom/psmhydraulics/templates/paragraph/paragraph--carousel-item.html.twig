<article{{ attributes.addClass('carousel-slide') }}>
  <div class="carousel-slide__media">
    {{ content.field_image }}
  </div>

  <div class="carousel-slide__overlay"></div>

  <div class="carousel-slide__content">
    {% if content.field_eyebrow %}
      <div class="carousel-slide__eyebrow">
        {{ content.field_eyebrow }}
      </div>
    {% endif %}

    {% if content.field_heading %}
      <div class="carousel-slide__heading">
        {{ content.field_heading }}
      </div>
    {% endif %}

    {% if content.field_description %}
      <div class="carousel-slide__description">
        {{ content.field_description }}
      </div>
    {% endif %}

    {% if content.field_link %}
      <div class="carousel-slide__link" data-carousel-pause-trigger>
        {{ content.field_link }}
      </div>
    {% endif %}
  </div>
</article>
